# Vercel environment template for the backend project (services/voice-api)

ENVIRONMENT=production
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DIRECT_POSTGRES_URL=postgresql://username:password@host:5432/postgres
VAPI_API_KEY=your_vapi_private_key
GEMINI_API_KEY=your_gemini_api_key

# Optional overrides
VOICE_API_BASE_URL=https://your-voice-api.vercel.app
VAPI_PUBLIC_BASE_URL=https://your-voice-api.vercel.app
